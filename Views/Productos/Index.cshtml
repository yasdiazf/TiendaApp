@model IEnumerable<TiendaApp.Models.Producto>

@{
    ViewData["Title"] = "Lista de Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Gestión de Productos</h2>
    <a asp-action="Create" class="btn btn-primary">➕ Crear Nuevo Producto</a>
</div>

<table class="table table-striped table-hover shadow-sm rounded">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Nombre)</th>
            <th>@Html.DisplayNameFor(model => model.Precio)</th>
            <th>@Html.DisplayNameFor(model => model.Stock)</th>
            <th>@Html.DisplayNameFor(model => model.FechaVencimiento)</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
            <td>Bs. @Html.DisplayFor(modelItem => item.Precio)</td>
            <td>@Html.DisplayFor(modelItem => item.Stock)</td>
            <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
            <td class="text-center">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"> Editar</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"> Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>