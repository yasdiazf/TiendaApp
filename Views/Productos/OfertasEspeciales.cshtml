@model IEnumerable<TiendaApp.Models.Producto>

@{
    ViewData["Title"] = "Ofertas Especiales";
}

<div class="container-fluid mt-3">
    <!-- Banner de Ofertas -->
    <div class="p-3 mb-4 bg-gradient bg-danger text-white rounded-3 shadow-sm d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0">🔥 Promociones y Liquidación</h2>
            <small class="mb-0">Descuento automático del <strong>20% OFF</strong> en productos por vencimiento próximo.</small>
        </div>
        <span class="badge bg-warning text-dark fs-5 p-2 shadow">⚡ 20% DESC</span>
    </div>

    <div class="row">
        <!-- COLUMNA IZQUIERDA: CATÁLOGO DE OFERTAS (8 COLUMNAS) -->
        <div class="col-md-8">
            @if (Model != null && Model.Any())
            {
                <div class="row g-3">
                    @foreach (var prod in Model)
                    {
                        var precioOriginal = prod.Precio;
                        var precioOferta = precioOriginal * 0.80m;
                        var diasRestantes = (prod.FechaVencimiento - DateTime.UtcNow).Days;

                        <div class="col-md-6 col-lg-6">
                            <div class="card h-100 border-danger shadow-sm position-relative">
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger z-1">
                                    -20%
                                </span>
                                
                                <div class="card-header bg-light text-center border-bottom-0 pt-3">
                                    <h5 class="fw-bold text-dark mb-0">@prod.Nombre</h5>
                                    <small class="text-muted">Stock: @prod.Stock</small>
                                </div>

                                <div class="card-body text-center d-flex flex-column justify-content-between">
                                    <div class="my-1">
                                        <p class="text-muted mb-0">
                                            <small>Precio Normal: <del>Bs. @precioOriginal.ToString("N2")</del></small>
                                        </p>
                                        <p class="text-danger fw-bold fs-3 mb-1">
                                            Bs. @precioOferta.ToString("N2")
                                        </p>
                                        
                                        <div class="badge bg-warning text-dark px-2 py-1">
                                            ⏰ Vence en @diasRestantes días
                                        </div>
                                    </div>

                                    <button type="button" class="btn btn-outline-danger w-100 mt-3 fw-bold"
                                            onclick="agregarAlCarrito('@prod.Nombre', @precioOferta.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))">
                                        🛒 Agregar Oferta
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    No hay productos en liquidación en este momento.
                </div>
            }
        </div>

        <!-- COLUMNA DERECHA: RESUMEN DE SELECCIÓN (4 COLUMNAS) -->
        <div class="col-md-4 mt-4 mt-md-0">
            <div class="card shadow border-dark sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">🛒 Tu Selección</h5>
                    <span class="badge bg-danger" id="totalItems">0 ítems</span>
                </div>
                <div class="card-body p-2" style="max-height: 350px; overflow-y: auto;">
                    <ul class="list-group list-group-flush" id="listaCarrito">
                        <li class="list-group-item text-muted text-center py-4" id="carritoVacio">
                            Aún no has agregado productos.
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex justify-content-between fs-5 fw-bold mb-3">
                        <span>Total a Pagar:</span>
                        <span class="text-danger" id="totalPagar">Bs. 0.00</span>
                    </div>
                    <button class="btn btn-success w-100 fw-bold py-2" id="btnConfirmar" disabled onclick="confirmarPedidoBD()">
                        ✅ Confirmar Pedido
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- CDN de SweetAlert2 para modales y alertas estilizadas -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let carrito = [];

        function agregarAlCarrito(nombre, precio) {
            let item = carrito.find(p => p.nombre === nombre);
            if (item) {
                item.cantidad++;
            } else {
                carrito.push({ nombre: nombre, precio: parseFloat(precio), cantidad: 1 });
            }
            actualizarVistaCarrito();
        }

        function cambiarCantidad(nombre, cambio) {
            let item = carrito.find(p => p.nombre === nombre);
            if (item) {
                item.cantidad += cambio;
                if (item.cantidad <= 0) {
                    carrito = carrito.filter(p => p.nombre !== nombre);
                }
            }
            actualizarVistaCarrito();
        }

        function actualizarVistaCarrito() {
            const ul = document.getElementById("listaCarrito");
            const totalPagarEl = document.getElementById("totalPagar");
            const totalItemsEl = document.getElementById("totalItems");
            const btnConfirmar = document.getElementById("btnConfirmar");

            ul.innerHTML = "";
            let total = 0;
            let totalCantidad = 0;

            if (carrito.length === 0) {
                ul.innerHTML = `<li class="list-group-item text-muted text-center py-4">Aún no has agregado productos.</li>`;
                btnConfirmar.disabled = true;
            } else {
                carrito.forEach(item => {
                    let subtotal = item.precio * item.cantidad;
                    total += subtotal;
                    totalCantidad += item.cantidad;

                    let li = document.createElement("li");
                    li.className = "list-group-item d-flex justify-content-between align-items-center px-2 py-2";
                    li.innerHTML = `
                        <div>
                            <strong class="d-block text-truncate" style="max-width: 130px;">${item.nombre}</strong>
                            <small class="text-muted">Bs. ${item.precio.toFixed(2)} c/u</small>
                        </div>
                        <div class="d-flex align-items-center">
                            <button class="btn btn-sm btn-outline-secondary px-2 py-0" onclick="cambiarCantidad('${item.nombre}', -1)">-</button>
                            <span class="mx-2 fw-bold">${item.cantidad}</span>
                            <button class="btn btn-sm btn-outline-secondary px-2 py-0" onclick="cambiarCantidad('${item.nombre}', 1)">+</button>
                        </div>
                        <span class="fw-bold text-danger">Bs. ${subtotal.toFixed(2)}</span>
                    `;
                    ul.appendChild(li);
                });
                btnConfirmar.disabled = false;
            }

            totalPagarEl.innerText = `Bs. ${total.toFixed(2)}`;
            totalItemsEl.innerText = `${totalCantidad} ítems`;
        }

        // FUNCIÓN CON SWEETALERT2 PARA CONFIRMAR LA COMPRA
        async function confirmarPedidoBD() {
            const btnConfirmar = document.getElementById("btnConfirmar");
            btnConfirmar.disabled = true;

            try {
                const response = await fetch('/Productos/ProcesarVentaOferta', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(carrito)
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Venta Registrada!',
                        text: data.message,
                        confirmButtonColor: '#198754',
                        confirmButtonText: 'Excelente'
                    }).then(() => {
                        carrito = [];
                        actualizarVistaCarrito();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'No se pudo procesar',
                        text: data.message,
                        confirmButtonColor: '#dc3545'
                    });
                    btnConfirmar.disabled = false;
                }
            } catch (error) {
                console.error(error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error de conexión',
                    text: 'Ocurrió un problema al conectar con el servidor.',
                    confirmButtonColor: '#dc3545'
                });
                btnConfirmar.disabled = false;
            }
        }
    </script>
}