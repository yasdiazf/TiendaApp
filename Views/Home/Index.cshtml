@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 border text-center shadow-sm">
        <div class="container-fluid py-3">
            <h1 class="display-4 fw-bold text-primary">Bienvenido a "La Económica"</h1>
            <p class="fs-5 text-muted">Sistema Web de Gestión de Inventarios y Productos.</p>
            <hr class="my-4">
            
            @if (Context.Session.GetString("UsuarioNombre") == null)
            {
                <a class="btn btn-primary btn-lg px-4 fw-bold shadow-sm" asp-controller="Account" asp-action="Login">
                    🔑 Iniciar Sesión para Continuar
                </a>
            }
            else
            {
                <a class="btn btn-success btn-lg px-4 fw-bold shadow-sm" asp-controller="Productos" asp-action="Index">
                    📦 Ir a Gestión de Productos
                </a>
            }
        </div>
    </div>
</div>