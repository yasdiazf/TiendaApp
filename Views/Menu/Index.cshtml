@{
    ViewData["Title"] = "Menú Principal";
}

<div class="container mt-4">
    <h2>Menú Principal</h2>
    <p class="text-muted">Sesión activa para Usuario ID: <strong>@ViewBag.UsuarioId</strong> (Rol: <strong>@ViewBag.Rol</strong>)</p>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-center mb-3">
                <div class="card-body">
                    <h5 class="card-title">Clientes</h5>
                    <p class="card-text">Consulta de datos de clientes.</p>
                    <a href="#" class="btn btn-secondary disabled">Ver Clientes</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center mb-3">
                <div class="card-body">
                    <h5 class="card-title">Artículos / Productos</h5>
                    <p class="card-text">Gestión del catálogo (Solo Almacén).</p>
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-primary">Ir a Artículos</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center mb-3">
                <div class="card-body">
                    <h5 class="card-title">Ventas</h5>
                    <p class="card-text">Registro de ventas (Solo Vendedor).</p>
                    <a asp-controller="Ventas" asp-action="Index" class="btn btn-success">Ir a Ventas</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger">Cerrar Sesión</a>
    </div>
</div>